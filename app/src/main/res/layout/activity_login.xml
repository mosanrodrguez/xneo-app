<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp"
        android:layout_gravity="center">

        <!-- Logo XNEO grande -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X"
                android:textSize="56sp"
                android:textStyle="bold"
                android:textColor="#E53935"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEO"
                android:textSize="56sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTENIDO EXCLUSIVO"
            android:textColor="#888888"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="48dp"/>

        <!-- Card del formulario -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Tabs -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/tab_login"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Iniciar Sesión"
                        android:textColor="#E53935"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:gravity="center"
                        android:paddingBottom="12dp"
                        android:background="@drawable/tab_active_bg"/>

                    <TextView
                        android:id="@+id/tab_register"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Crear Cuenta"
                        android:textColor="#888888"
                        android:textSize="15sp"
                        android:gravity="center"
                        android:paddingBottom="12dp"
                        android:background="@drawable/tab_inactive_bg"/>
                </LinearLayout>

                <!-- Login Form -->
                <LinearLayout
                    android:id="@+id/login_form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Usuario"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/et_login_user"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Tu usuario"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:background="@drawable/edit_text_bg"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contraseña"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/et_login_pass"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Tu contraseña"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:background="@drawable/edit_text_bg"
                        android:inputType="textPassword"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:id="@+id/login_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#E53935"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"/>

                    <Button
                        android:id="@+id/btn_login"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Iniciar Sesión"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:backgroundTint="#E53935"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:cornerRadius="14dp"/>
                </LinearLayout>

                <!-- Register Form -->
                <LinearLayout
                    android:id="@+id/register_form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Usuario"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/et_reg_user"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Elige un usuario"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/edit_text_bg"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contraseña"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/et_reg_pass"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Mínimo 6 caracteres"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/edit_text_bg"
                        android:inputType="textPassword"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Confirmar Contraseña"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/et_reg_confirm"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Repite la contraseña"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/edit_text_bg"
                        android:inputType="textPassword"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:id="@+id/reg_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#E53935"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/reg_success"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#4CAF50"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"/>

                    <Button
                        android:id="@+id/btn_register"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Registrarse"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:backgroundTint="#E53935"
                        app:cornerRadius="14dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
